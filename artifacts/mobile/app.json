{
  "expo": {
    "name": "Pro Fitness AI",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1D1D1B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.replit.profitnessai",
      "usesAppleSignIn": true,
      "buildNumber": "19",
      "infoPlist": {
        "NSHealthShareUsageDescription": "Your fitness data is used to track your workout progress and provide personalized insights within the app.",
        "NSHealthUpdateUsageDescription": "Pro Fitness AI may write completed workout data to Apple Health to keep your fitness records synchronized across apps.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.background-delivery": true
      }
    },
    "android": {
      "backgroundColor": "#1D1D1B"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-apple-authentication",
      "react-native-health"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "3f93f71c-bfa3-43b3-96c5-070d97b2ce4e"
      }
    }
  }
}
