{
  "expo": {
    "name": "Pro Fitness AI",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1D1D1B"
    },
    "ios": {
      "supportsTablet": false,
      "usesAppleSignIn": true,
      "buildNumber": "3",
      "infoPlist": {
        "NSHealthShareUsageDescription": "Your fitness data is used to track your workout progress and provide personalized insights within the app.",
        "NSHealthUpdateUsageDescription": "Pro Fitness AI may write completed workout data to Apple Health to keep your fitness records synchronized across apps."
      }
    },
    "android": {
      "backgroundColor": "#1D1D1B"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}